{
  "name": "mushkila-wa-hal",
  "version": "1.0.0",
  "private": true,
  "description": "مشكلة وحل — منصة المعلمين التعاونية",
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "db:migrate": "npm run db:migrate --prefix server",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently -n SERVER,CLIENT -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "build": "npm run build --prefix client",
    "start": "cross-env NODE_ENV=production npm run start --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3"
  }
}
