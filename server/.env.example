# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit real credentials.

# --- Local development ---
# If you installed Postgres locally:
# DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/mushkila

# --- Production (Render / Railway / etc.) ---
# Paste the connection string your host gives you for the Postgres
# database it provisions for you. It usually looks like:
# DATABASE_URL=postgres://user:password@host:5432/dbname

DATABASE_URL=postgres://postgres:postgres@localhost:5432/mushkila

# Most local Postgres installs don't have SSL configured — turn it off.
# Render/Railway-hosted Postgres needs SSL, so this should be left unset
# (or set to "true") in production.
DATABASE_SSL=false

PORT=5000
